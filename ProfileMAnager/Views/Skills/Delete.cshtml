@model ProfileMAnager.Models.Skill
@{ ViewData["Title"] = "Apagar Skill"; }

<h2>Apagar Skill</h2>
<h3>Tem a certeza que deseja apagar esta skill?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>  
    </dl>
    
    @if (ViewBag.PodeApagar == false) {
        <div class="alert alert-warning">
            Esta skill não pode ser apagada porque está associada a talentos.
        </div>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    } else {
        <form asp-action="Delete" asp-route-id="@Model.Idskill" method="post">
            <input type="hidden" asp-for="Idskill" />
            <input type="submit" value="Apagar" class="btn btn-danger" /> |
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    }
</div>