@model IEnumerable<ProfileMAnager.Models.Skill>

@{
    ViewData["Title"] = "Gestão de Skills";
}

@* Cabeçalho Uniformizado *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-mortarboard"></i> Biblioteca de Skills</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Adicionar Nova Skill
    </a>
</div>

@* Mensagens de Erro Uniformizadas *@
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* Card com Tabela Uniformizada *@
<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Nome da Competência</th>
                    <th>Área Profissional</th>
                    <th class="text-end pe-4">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Nome</td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                @(item.IdareaNavigation?.Nome ?? "Geral")
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Idskill" class="btn btn-primary btn-sm">
                                    Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Idskill" class="btn btn-danger btn-sm">
                                    Apagar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <p class="text-muted italic">Ainda não foram registadas competências na biblioteca.</p>
    </div>
}