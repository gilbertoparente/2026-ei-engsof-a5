@model ProfileMAnager.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Bem-vindo";
}

<!-- 1. Estilos Externos (Bibliotecas e o teu novo CSS isolado) -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

<!-- 2. Estrutura da Página -->
<div class="hero-section py-5">
    <div class="container text-center">
        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto">
                
                <!-- LOGÓTIPO COM O DOBRO DO TAMANHO (Classe aplicada) -->
                <div class="mb-5" data-aos="fade-down" data-aos-duration="1000">
                    <img src="~/css/logo.png" alt="ProfileManager Logo" class="img-fluid landing-logo" />
                </div>
                
                <!-- TÍTULO PRINCIPAL -->
                <h1 class="display-3 fw-bold text-dark mb-3" data-aos="fade-up" data-aos-delay="200" data-aos-duration="1000">
                    Plataforma de <span class="text-primary">Talentos</span>
                </h1>
                
                <!-- SUBTÍTULO -->
                <p class="lead text-muted mb-4 fs-4" data-aos="fade-up" data-aos-delay="400" data-aos-duration="1000">
                    A infraestrutura inteligente para gestão de competências, perfis tecnológicos e propostas de engenharia de software.
                </p>
                
                <!-- BOTÃO DE CHAMADA DE AÇÃO -->
                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center" data-aos="zoom-in" data-aos-delay="600" data-aos-duration="800">
                    <a asp-controller="Conta" asp-action="Login" class="btn btn-primary btn-lg px-5 py-3 shadow fw-bold hover-animate">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Aceder à Plataforma
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Secção de Características Técnicas -->
<div class="container my-5 py-5">
    <div class="row text-center g-4">
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
            <div class="feature-card">
                <i class="bi bi-shield-check text-primary fs-1 mb-3"></i>
                <h5>Segurança Proxy</h5>
                <p class="text-muted small">Camada de controlo de acessos estruturada sob o padrão de desenho Proxy.</p>
            </div>
        </div>
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
            <div class="feature-card">
                <i class="bi bi-lightning-charge text-primary fs-1 mb-3"></i>
                <h5>Match Inteligente</h5>
                <p class="text-muted small">Algoritmo restrito de interseção booleana para filtragem exata de skills.</p>
            </div>
        </div>
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
            <div class="feature-card">
                <i class="bi bi-pie-chart text-primary fs-1 mb-3"></i>
                <h5>Estratégia de Relatórios</h5>
                <p class="text-muted small">Múltiplas visões analíticas implementadas com o Strategy Pattern.</p>
            </div>
        </div>
    </div>
</div>

<!-- 3. Ativação do Motor das Animações -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        once: true 
    });
</script>

<div class="container text-center py-5 my-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mx-auto">
            <div class="mb-4">
                <img src="~/css/logo.png" alt="ProfileManager Logo" class="img-fluid" style="max-height: 120px; width: auto;" />
            </div>
            
            <h1 class="display-4 fw-bold text-dark mb-3">ProfileManager</h1>
            <p class="lead text-muted mb-4">
                A plataforma inteligente para gestão de competências, perfis de talento e propostas de trabalho. Encontre o match perfeito para o seu projeto.
            </p>
            
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a asp-controller="Conta" asp-action="Login" class="btn btn-primary btn-lg px-5 shadow">
                    <i class="bi bi-box-arrow-in-right"></i> Entrar na Plataforma
                </a>
            </div>
        </div>
    </div>
</div>

