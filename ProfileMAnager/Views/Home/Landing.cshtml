@model ProfileMAnager.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Bem-vindo";
}

<div class="container text-center py-5 my-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mx-auto">
            <div class="mb-4">
                <img src="~/css/logo.png" alt="ProfileManager Logo" class="img-fluid" style="max-height: 120px; width: auto;" />
            </div>
            
            <h1 class="display-4 fw-bold text-dark mb-3">ProfileManager</h1>
            <p class="lead text-muted mb-4">
                A plataforma inteligente para gestão de competências, perfis de talento e propostas de trabalho. Encontre o match perfeito para o seu projeto.
            </p>
            
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a asp-controller="Conta" asp-action="Login" class="btn btn-primary btn-lg px-5 shadow">
                    <i class="bi bi-box-arrow-in-right"></i> Entrar na Plataforma
                </a>
            </div>
        </div>
    </div>
</div>