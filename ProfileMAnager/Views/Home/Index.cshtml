@model ProfileMAnager.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Olá, @Model.NomeUtilizador! 👋</h2>
        <span class="badge bg-secondary p-2">@DateTime.Now.ToString("dd MMMM, yyyy")</span>
    </div>

    <!-- KPI CARDS (Os quadrados agora são compactos e elegantes) -->
    <div class="row g-3 mb-5">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 py-2 border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1 small">Total Talentos</div>
                            <div class="h4 mb-0 fw-bold text-dark">@Model.TotalTalentos</div>
                        </div>
                        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                            <i class="bi bi-person-badge text-primary fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 py-2 border-start border-success border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1 small">Propostas Ativas</div>
                            <div class="h4 mb-0 fw-bold text-dark">@Model.TotalPropostas</div>
                        </div>
                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                            <i class="bi bi-file-earmark-text text-success fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 py-2 border-start border-info border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1 small">Clientes</div>
                            <div class="h4 mb-0 fw-bold text-dark">@Model.TotalClientes</div>
                        </div>
                        <div class="rounded-circle bg-info bg-opacity-10 p-3">
                            <i class="bi bi-briefcase text-info fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CARD DE ACESSO RÁPIDO AO PERFIL -->
        <div class="col-12 col-sm-6 col-xl-3">
            <a asp-controller="Conta" asp-action="Perfil" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 py-2 bg-dark text-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-light text-uppercase mb-1 small">Minha Conta</div>
                                <div class="small text-light text-opacity-75">Gerir Perfil →</div>
                            </div>
                            <div class="rounded-circle bg-white bg-opacity-20 p-3">
                                <i class="bi bi-gear-fill text-white fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- ÁREA DE LISTAGEM (Ocupa o resto da página) -->
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Novos Talentos Registados</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Nome</th>
                                    <th>Categoria</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var talento in Model.NovosTalentos)
                                {
                                    <tr>
                                        <td>@talento.Nome</td>
                                        <td>@talento.IdcategoriaNavigation?.Nome</td>
                                        <td><a class="btn btn-sm btn-outline-primary" asp-controller="Talentos" asp-action="Details" asp-route-id="@talento.Idtalento">Ver</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 text-center">
                    <h6 class="m-0 fw-bold text-dark">Informações do Sistema</h6>
                </div>
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <div class="mb-3">
                        <i class="bi bi-shield-check text-success fs-1"></i>
                    </div>
                    <p class="text-muted small px-3">
                        Acesso protegido pelo <strong>DashboardServiceProxy</strong>. 
                        As suas informações estão seguras através de encriptação de cookies.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>