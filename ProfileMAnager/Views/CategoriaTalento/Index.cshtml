@model IEnumerable<ProfileMAnager.Models.Categoriatalento>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-tags"></i> Categorias de Talento</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova Categoria</a>
    </div>

    @* Removi a classe bg-white daqui para não dar conflito *@
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark"> @* Agora o CSS acima vai deixar isto ser preto *@
                    <tr>
                        <th class="ps-4 py-3">Descrição / Nome</th>
                        <th class="text-end pe-4 py-3">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4 align-middle fw-bold">@item.Nome</td>
                            <td class="text-end pe-4">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Idcategoria" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Idcategoria" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>