@model ProfileMAnager.Models.Categoriatalento

@{
    ViewData["Title"] = "Editar Categoria";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg" style="border-radius: 12px; overflow: hidden;">
                
                @* Cabeçalho com Fundo Preto Profundo *@
                <div class="card-header bg-dark py-3 border-0">
                    <h4 class="mb-0 text-white text-center">
                        <i class="bi bi-pencil-square me-2"></i>Editar Categoria
                    </h4>
                </div>

                <div class="card-body p-5 bg-white">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Idcategoria" />
                        
                        <div class="mb-4">
                            <label asp-for="Nome" class="form-label fw-bold text-secondary">Nome da Categoria</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-tag text-primary"></i></span>
                                <input asp-for="Nome" class="form-control form-control-lg border-start-0 ps-0" 
                                       placeholder="Ex: Desenvolvimento Web" required />
                            </div>
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Index" class="text-decoration-none text-muted fw-bold">
                                <i class="bi bi-arrow-left"></i> Voltar à lista
                            </a>
                            
                            <div class="d-flex gap-2">
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                    Cancelar
                                </a>
                                <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                    <i class="bi bi-save me-2"></i>Gravar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
            @* Dica visual para o utilizador *@
            <div class="text-center mt-4">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i> 
                    Certifique-se de que o nome é único para evitar duplicados no sistema.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}