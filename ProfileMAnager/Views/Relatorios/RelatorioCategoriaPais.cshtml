@model List<ProfileMAnager.Models.RelatorioCategoriaPaisVM>

@{
    ViewData["Title"] = "Relatório por Categoria e País";
}

<div class="container mt-4">

    <h2 class="mb-4">
        Relatório de Talentos
    </h2>

    <form method="get" class="row g-3 mb-4">

        <!-- Categoria -->
        <div class="col-md-4">
            <label class="form-label">Categoria</label>

            <select name="categoria" class="form-select">

                <option value="">
                    Todas
                </option>

                @foreach (var categoria in ViewBag.Categorias)
                {
                    <option value="@categoria">
                        @categoria
                    </option>
                }

            </select>
        </div>

        <!-- País -->
        <div class="col-md-4">
            <label class="form-label">País</label>

            <select name="pais" class="form-select">

                <option value="">
                    Todos
                </option>

                @foreach (var pais in ViewBag.Paises)
                {
                    <option value="@pais">
                        @pais
                    </option>
                }

            </select>
        </div>

        <!-- Skill -->
        <div class="col-md-4">
            <label class="form-label">Skill</label>

            <select name="skill" class="form-select">

                <option value="">
                    Todas
                </option>

                @foreach (var skill in ViewBag.Skills)
                {
                    <option value="@skill">
                        @skill
                    </option>
                }

            </select>
        </div>

        <!-- Botão -->
        <div class="col-md-2 align-self-end">
            <button type="submit"
                    class="btn btn-primary w-100">
                Filtrar
            </button>
        </div>

    </form>

    <table class="table table-striped table-bordered">

        <thead class="table-dark">
            <tr>
                <th>Categoria</th>
                <th>País</th>
                <th>Skill</th>
                <th>Total de Talentos</th>
                <th>Preço Médio Mensal (€)</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Categoria</td>
                <td>@item.Pais</td>
                <td>@item.Skill</td>
                <td>@item.Total</td>
                <td>@item.PrecoMedioMensal.ToString("F2")</td>
            </tr>
        }

        </tbody>

    </table>

</div>