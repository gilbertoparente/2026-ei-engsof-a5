@model IEnumerable<ProfileMAnager.Models.RelatorioCategoriaPaisVM>

@{
    ViewData["Title"] = "Relatório por Categoria e País";
}

<h2>Relatório por Categoria e País</h2>

<form method="get" class="row mb-3">

    <div class="col-md-4">
        <label class="form-label">Categoria</label>
        <select name="categoria" class="form-control">
            <option value="">Todas</option>
            @foreach (var cat in ViewBag.Categorias)
            {
                <option value="@cat"
                        selected="@(Context.Request.Query["categoria"] == cat ? "selected" : null)">
                    @cat
                </option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">País</label>
        <select name="pais" class="form-control">
            <option value="">Todos</option>
            @foreach (var pais in ViewBag.Paises)
            {
                <option value="@pais"
                        selected="@(Context.Request.Query["pais"] == pais ? "selected" : null)">
                    @pais
                </option>
            }
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary">
            Filtrar
        </button>
    </div>

</form>


<table class="table table-striped table-bordered">

    <thead>
        <tr>
            <th>Categoria</th>
            <th>País</th>
            <th>Total de Talentos</th>
            <th>Preço Médio Mensal (€)</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="4" class="text-center">
                    Nenhum resultado encontrado.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Categoria</td>
                    <td>@item.Pais</td>
                    <td>@item.Total</td>
                    <td>@item.PrecoMedioMensal.ToString("F2")</td>
                </tr>
            }
        }
    </tbody>

</table>