@model IEnumerable<ProfileMAnager.Models.Talento>
@{ ViewData["Title"] = "Meus Talentos"; }

<div class="container mt-4">
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Os Meus Perfis de Talento</h2><a asp-action="Create" class="btn btn-outline-primary">
        <i class="bi bi-plus-lg"></i> Criar Novo Perfil
    </a>
</div>

    <div class="row">
        @foreach (var item in Model) {
            <div class="col-md-4 mb-4"> @* mb-4 para espaçamento vertical entre linhas *@
                <div class="card h-100 shadow-sm border-0"> @* h-100 força o card a esticar *@
                    <div class="card-body d-flex flex-column"> @* d-flex flex-column permite empurrar os botões *@
                        
                        <div class="mb-2">
                            <h5 class="card-title fw-bold mb-1">@item.Nome</h5>
                            <small class="text-muted d-block mb-2">
                                <i class="bi bi-tag"></i> @(item.IdcategoriaNavigation?.Nome ?? "Geral")
                            </small>
                        </div>
    
                        @* flex-grow-1 faz este parágrafo ocupar todo o espaço disponível, empurrando o resto para baixo *@
                        <div class="card-text flex-grow-1">
                            <p class="mb-1"><strong>País:</strong> @item.Pais</p>
                            <p><strong>Preço/Hora:</strong> <span class="text-primary fw-bold">@item.Precohora.ToString("N2")€</span></p>
                        </div>
    
                        <div class="mt-auto"> @* mt-auto garante que isto fica sempre no fundo *@
                            <hr />
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge border @(item.Publico == true ? "text-primary border-primary" : "text-secondary border-secondary")" style="background-color: white !important;">
                                    @(item.Publico == true ? "Público" : "Privado")
                                </span>
                            </div>
    
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Idtalento" class="btn btn-outline-primary btn-sm flex-grow-1">
                                    Ver Detalhes
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Idtalento" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Idtalento" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any()) {
        <div class="alert alert-info text-center mt-3">Ainda não criou nenhum perfil de talento.</div>
    }
</div>