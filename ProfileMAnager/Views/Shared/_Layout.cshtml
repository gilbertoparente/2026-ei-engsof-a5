<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - ProfileManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>

<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-1">
        <div class="container-fluid mx-lg-5"> <a class="navbar-brand fw-bold fs-5" asp-controller="Home" asp-action="Index">ProfileManager</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto" style="font-size: 0.9rem;">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Skills" asp-action="Index">Skills</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Categoriatalento" asp-action="Index">Categorias</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Talentos" asp-action="Index">Os Meus Perfis</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Pesquisa" asp-action="Index">Pesquisar</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Propostas" asp-action="Index">Propostas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Relatorios" asp-action="RelatorioCategoriaPais">Relatórios</a></li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="navbar-text text-light me-2 d-none d-xl-inline">Olá, <strong>@User.Identity.Name</strong></span>
                        <a class="btn btn-danger btn-sm py-0 px-2" asp-controller="Conta" asp-action="Logout" style="font-size: 0.8rem;">Sair</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-light btn-sm py-1" asp-controller="Conta" asp-action="Login">Login</a>
                        <a class="btn btn-primary btn-sm py-1" asp-controller="Conta" asp-action="Registo">Registo</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>

<div class="container mt-4">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="border-top text-muted mt-5">
    <div class="container text-center py-3">
        © 2026 - ProfileManager - Projeto Académico
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>