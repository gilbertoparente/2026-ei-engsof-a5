<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Plataforma de Talentos </title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="bg-light">

<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-2">
        <div class="container-fluid mx-lg-5"> 
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="bi bi-cpu"></i>  Plataforma de Talentos
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto" style="font-size: 0.95rem;">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Skills" asp-action="Index">Skills</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Categoriatalento" asp-action="Index">Categorias</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Talentos" asp-action="Index">Talentos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Propostas" asp-action="Index">Propostas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Relatorios" asp-action="RelatorioCategoriaPais">Relatórios</a></li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="text-light d-none d-xl-block">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </div>
                        <a class="btn btn-outline-danger btn-sm fw-bold px-3" asp-controller="Conta" asp-action="Logout">Sair</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-info btn-sm px-3 fw-bold" asp-controller="Conta" asp-action="Login">Login</a>
                        <a class="btn btn-primary btn-sm px-3 fw-bold" asp-controller="Conta" asp-action="Registo">Registo</a>
                    }
                </div>
            </div>
        </div>
    </nav>
</header>


<div class="@(User.Identity.IsAuthenticated ? "container mt-4" : "container-fluid")">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="border-top text-muted mt-5 bg-white">
    <div class="container text-center py-4">
        <small>© 2026 - <strong> Plataforma de Talentos</strong> - Engenharia de Software</small>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>