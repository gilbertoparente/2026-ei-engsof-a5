<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - ProfileManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>

<header>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">ProfileManager</a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
         <ul class="navbar-nav me-auto">
             @if (User.Identity.IsAuthenticated)
             {
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                 </li>
         
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Skills" asp-action="Index">Skills</a>
                 </li>
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Categoriatalento" asp-action="Index">Categorias</a>
                 </li>
         
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Talentos" asp-action="Index">Os Meus Perfis</a>
                 </li>
         
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                 </li>
         
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Pesquisa" asp-action="Index">Pesquisar Talentos</a>
                 </li>
         
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Propostas" asp-action="Index">Propostas</a>
                 </li>
                 
                 <li class="nav-item">
                     <a class="nav-link" asp-controller="Talentos" asp-action="RelatorioCategoriaPais">Relatório Categoria e País</a>
                 </li>
             }
         </ul>

            <div class="d-flex gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="navbar-text me-3">Olá, @User.Identity.Name</span>
                    <a class="btn btn-danger btn-sm" asp-controller="Conta" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Conta" asp-action="Login">Login</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Conta" asp-action="Registo">Registar</a>
                }
            </div>
        </div>
    </div>
</nav>
</header>

<div class="container mt-4">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="border-top text-muted mt-5">
    <div class="container text-center py-3">
        © 2026 - ProfileManager - Projeto Académico
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>