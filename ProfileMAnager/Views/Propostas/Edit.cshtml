    @model ProfileMAnager.Models.Propostatrabalho

    @{
        ViewData["Title"] = "Editar Proposta";
    }

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Editar Proposta</h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Voltar à Lista</a>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Idproposta" />
                    <input type="hidden" asp-for="Idutilizador" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nome" class="form-label font-weight-bold"></label>
                            <input asp-for="Nome" class="form-control" placeholder="Nome da proposta" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cliente</label>
                            <select asp-for="Idcliente" class="form-select" asp-items="@(new SelectList(ViewBag.Clientes, "Idcliente", "Nome"))"></select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Categoria</label>
                            <select asp-for="Idcategoria" class="form-select" asp-items="@(new SelectList(ViewBag.Categorias, "Idcategoria", "Nome"))"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="form-label">Estado da Proposta</label>
                            <select asp-for="Estado" class="form-select">
                                <option value="ABERTA">Aberta</option>
                                <option value="EM CURSO">Em Curso</option>
                                <option value="FECHADA">Fechada</option>
                                <option value="CANCELADA">Cancelada</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Horastotais" class="form-label">Horas Totais Estimadas</label>
                            <input asp-for="Horastotais" class="form-control" type="number" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descricao" class="form-label font-weight-bold">Descrição do Trabalho</label>
                        <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Detalhes da proposta..."></textarea>
                    </div>

                    <hr />
                    <h5 class="mb-3"><i class="bi bi-gear-fill"></i> Competências Necessárias</h5>
                    <div class="card p-3 mb-4 bg-light">
                        <div class="row">
                            @foreach (var skill in (IEnumerable<ProfileMAnager.Models.Skill>)ViewBag.Skills)
                            {
                                var associada = Model.Propostaskills?.FirstOrDefault(ps => ps.Idskill == skill.Idskill);
                                bool isChecked = associada != null;

                                <div class="col-md-6 mb-2">
                                    <div class="d-flex align-items-center gap-2 border p-2 rounded bg-white shadow-sm">
                                        <input type="checkbox" name="selectedSkills" value="@skill.Idskill" 
                                               class="form-check-input ms-1" @(isChecked ? "checked" : "") />
                                        
                                        <label class="form-check-label flex-grow-1 mb-0">@skill.Nome</label>
                                        
                                        <div style="width: 110px;">
                                            <div class="input-group input-group-sm">
                                                <input type="number" name="anosMinimos" class="form-control" 
                                                       value="@(isChecked ? associada.Anosminimosexperiencia : 0)" min="0" />
                                                <span class="input-group-text">anos</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light border">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save"></i> Guardar Alterações
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">Talentos Associados</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nome</th>
                            <th>Data Início</th>
                            <th>Estado Atual</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PropostaTalentos != null && Model.PropostaTalentos.Any())
                        {
                            @foreach (var pt in Model.PropostaTalentos)
                            {
                                <tr>
                                    <td><span class="fw-bold text-primary">@(pt.Talento?.Nome ?? "N/A")</span></td>
                                    <td>@pt.Datainicio?.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge rounded-pill @(pt.Estado == "Aprovado" ? "bg-success" : (pt.Estado == "Rejeitado" ? "bg-danger" : "bg-warning text-dark"))">
                                            @pt.Estado
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <form asp-action="AlterarEstado" method="post" class="d-flex gap-1">
                                                <input type="hidden" name="id" value="@pt.Id" />
                                                <select name="estado" class="form-select form-select-sm" style="width: 130px;" onchange="this.form.submit()">
                                                    <option value="">Alterar...</option>
                                                    <option value="Pendente">Pendente</option>
                                                    <option value="Entrevistado">Entrevistado</option>
                                                    <option value="Aprovado">Aprovado</option>
                                                    <option value="Rejeitado">Rejeitado</option>
                                                </select>
                                            </form>
                                            <form asp-action="RemoverTalento" method="post" onsubmit="return confirm('Remover este talento?');">
                                                <input type="hidden" name="id" value="@pt.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">Nenhum talento associado.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>