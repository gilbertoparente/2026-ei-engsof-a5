@model IEnumerable<ProfileMAnager.Models.Talento>
@{ ViewData["Title"] = "Match por Skills"; }

<div class="container mt-4">
    <h2 class="fw-bold"><i class="bi bi-search-heart text-primary"></i> Pesquisar Talentos por Skills</h2>
    <hr />

    <form method="get" asp-action="Pesquisa">
        <div class="card p-4 mb-4 border-0 shadow-sm bg-light">
            <h5 class="mb-3">Selecione as Competências Desejadas:</h5>
            <div class="row">
                @foreach (var skill in (IEnumerable<ProfileMAnager.Models.Skill>)ViewBag.Skills)
                {
                    <div class="col-md-3 mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="skillIds" value="@skill.Idskill" 
                                   id="s_@skill.Idskill"
                                   @(ViewBag.SelectedSkills != null && ((int[])ViewBag.SelectedSkills).Contains(skill.Idskill) ? "checked" : "")>
                            <label class="form-check-label" for="s_@skill.Idskill">@skill.Nome</label>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">Pesquisar Talentos</button>
                <a asp-action="Pesquisa" class="btn btn-outline-secondary">Limpar Filtros</a>
            </div>
        </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>Resultados da Pesquisa (@Model.Count())</h4>
    </div>

    <div class="row">
        @foreach (var talento in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-primary">@talento.Nome</h5>
                        <p class="card-text small">
                            <strong>Categoria:</strong> @(talento.IdcategoriaNavigation?.Nome ?? "N/D")<br />
                            <strong>País:</strong> @talento.Pais | <strong>Preço/Hora:</strong> @talento.Precohora.ToString("N2")€
                        </p>
                        <a asp-action="Details" asp-route-id="@talento.Idtalento" class="btn btn-sm btn-info text-white">Ver Perfil Completo</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any() && ViewBag.SelectedSkills != null && ((int[])ViewBag.SelectedSkills).Length > 0)
    {
        <div class="alert alert-warning mt-3">Nenhum talento encontrado com as skills selecionadas.</div>
    }
</div>