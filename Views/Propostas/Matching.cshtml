@model List<ProfileMAnager.Models.Talento>
@{
    var proposta = ViewBag.Proposta as ProfileMAnager.Models.Propostatrabalho;
}

<h2>Talentos Elegíveis para: @proposta.Nome</h2>
<p class="text-muted">Ordenados por valor total (Custo x @proposta.Horastotais horas)</p>

<div class="row">
    @if (Model.Count == 0)
    {
        <div class="col-12">
            <div class="alert alert-warning">Nenhum talento cumpre todos os requisitos de skills desta proposta.</div>
        </div>
    }
    else
    {
        @foreach (var t in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@t.Nome</h5>
                        <p class="card-text">
                            <strong>País:</strong> @t.Pais<br />
                            <strong>Preço/Hora:</strong> @t.Precohora.ToString("C")<br />
                            <span class="badge bg-success">
                                Valor Total: @((t.Precohora * (proposta.Horastotais ?? 0)).ToString("C"))
                            </span>
                        </p>
                        <hr />
                        <h6>Skills do Talento:</h6>
                        <ul class="small flex-grow-1">
                            @foreach (var ts in t.Talentoskills)
                            {
                                <li>@ts.IdskillNavigation?.Nome - @ts.Anosexperiencia anos</li>
                            }
                        </ul>

                        <div class="mt-3">
                            <form asp-action="AtribuirTalento" method="post">
                                <input type="hidden" name="idProposta" value="@proposta.Idproposta" />
                                <input type="hidden" name="idTalento" value="@t.Idtalento" />
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-person-plus"></i> Atribuir à Proposta
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Voltar às Propostas</a>