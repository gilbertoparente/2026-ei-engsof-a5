@model ProfileMAnager.Models.Skill
@{ ViewData["Title"] = "Editar Skill"; }

<h2>Editar Skill</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Idskill" />
    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Área Profissional</label>
        <select asp-for="Idarea" class="form-control" asp-items="ViewBag.Idarea"></select>
    </div>
    <br />
    <input type="submit" value="Guardar" class="btn btn-success" />
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>