@model ProfileMAnager.Models.Skill
@{ ViewData["Title"] = "Adicionar Skill"; }

<h2>Adicionar Skill</h2>
<form asp-action="Create">
    <div class="form-group">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Área Profissional</label>
        <select asp-for="Idarea" class="form-control" asp-items="ViewBag.Idarea">
            <option value="">-- Selecione uma Área --</option>
        </select>
    </div>
    <br />
    <input type="submit" value="Criar" class="btn btn-success" />
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>