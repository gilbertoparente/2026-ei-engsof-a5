@model ProfileMAnager.Models.Cliente

<h2>Criar Cliente</h2>

<form method="post">
    
    <div class="mb-3">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="mb-3">
        <label>País</label>
        <input asp-for="Pais" class="form-control" />
    </div>

    <button class="btn btn-success">Criar</button>

</form>