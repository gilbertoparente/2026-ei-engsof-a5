@model List<ProfileMAnager.Models.Cliente>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Gestão de Clientes</h2>
    <a class="btn btn-primary" href="/Clientes/Create">+ Novo Cliente</a>
</div>

<div class="card shadow-sm">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Nome do Cliente</th>
                <th>País de Origem</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model) {
                <tr>
                    <td class="fw-bold">@c.Nome</td>
                    <td><span class="badge bg-light text-dark">@c.Pais</span></td>
                    <td class="text-end">
                        <a class="btn btn-primary btn-sm" href="/Clientes/Edit/@c.Idcliente">Editar</a>
                        <a class="btn btn-danger btn-sm" href="/Clientes/Delete/@c.Idcliente">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>