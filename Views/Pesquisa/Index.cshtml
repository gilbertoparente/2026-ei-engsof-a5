@model IEnumerable<ProfileMAnager.Models.Talento>

@{ ViewData["Title"] = "Pesquisa de Talentos"; }

<div class="container mt-4">
    <h2>Pesquisar Talentos por Skills</h2>
    <hr />

    <form method="get" asp-action="Index">
        <div class="card p-3 mb-4 bg-light">
            <h5>Selecione as Competências Desejadas:</h5>
            <div class="row">
                @foreach (var skill in (List<Skill>)ViewBag.Skills)
                {
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="skillIds" value="@skill.Idskill" 
                                   @(ViewBag.SelectedSkills != null && ((int[])ViewBag.SelectedSkills).Contains(skill.Idskill) ? "checked" : "")>
                            <label class="form-check-label">@skill.Nome</label>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Pesquisar Talentos</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar Filtros</a>
            </div>
        </div>
    </form>

    <h4>Resultados da Pesquisa (@Model.Count())</h4>
    <div class="row mt-3">
        @foreach (var talento in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@talento.Nome</h5>
                        <p class="card-text">
                            <strong>Categoria:</strong> @talento.IdcategoriaNavigation?.Nome<br />
                            <strong>País:</strong> @talento.Pais | <strong>Preço/Hora:</strong> @talento.Precohora.ToString("C")
                        </p>
                        <a asp-controller="Talentos" asp-action="Details" asp-route-id="@talento.Idtalento" class="btn btn-sm btn-info">Ver Perfil Completo</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any() && ViewBag.SelectedSkills != null && ((int[])ViewBag.SelectedSkills).Length > 0)
    {
        <div class="alert alert-warning">Nenhum talento público encontrado com todas as skills selecionadas.</div>
    }
</div>