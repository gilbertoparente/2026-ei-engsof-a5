@model IEnumerable<ProfileMAnager.Models.Categoriatalento>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Categorias de Talento</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova Categoria</a>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
            <tr>
                <th>Descrição / Nome</th>
                <th class="text-end">Ações</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle fw-bold">@item.Nome</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Idcategoria" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                                
                            <form asp-action="Delete" asp-route-id="@item.Idcategoria" method="post" 
                                  onsubmit="return confirm('Tem a certeza que deseja eliminar esta categoria?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Eliminar 
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>