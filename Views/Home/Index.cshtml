@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1>Profile Manager</h1>
        <p class="lead">Gestão de perfis profissionais IT</p>
        <p>Bem-vindo, <strong>@ViewBag.NomeUtilizador</strong></p>
    </div>

  <div class="row text-center">
  
       @* CARTÃO PERFIL / TALENTOS *@
         <div class="col-md-4 mb-3">
             <div class="card shadow">
                 <div class="card-body">
                     <h5 class="card-title">Perfil</h5>
                     <p class="card-text">Gerir os meus perfis de talento IT.</p>
                     <a asp-controller="Talentos" asp-action="Index" class="btn btn-primary w-100">Gerir Perfil</a>
                 </div>
             </div>
         </div>
  
         @* CARTÃO SKILLS *@
         <div class="col-md-4 mb-3">
             <div class="card shadow">
                 <div class="card-body">
                     <h5 class="card-title">Skills</h5>
                     <p class="card-text">Biblioteca global de competências.</p>
                     <a asp-controller="Skills" asp-action="Index" class="btn btn-primary w-100">Gerir Skills</a>
                 </div>
             </div>
         </div>
  
      @* CARTÃO PROPOSTAS - (Próxima etapa!) *@
         <div class="col-md-4 mb-3">
             <div class="card shadow">
                 <div class="card-body">
                     <h5 class="card-title">Propostas</h5>
                     <p class="card-text">Gerir propostas de trabalho.</p>
                     <a href="#" class="btn btn-secondary w-100 disabled">Ver Propostas</a>
                 </div>
             </div>
         </div>

  
  </div>

    <div class="text-center mt-5">
        <a href="/Conta/Logout" class="btn btn-danger">Logout</a>
    </div>

</div>