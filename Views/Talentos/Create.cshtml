@model ProfileMAnager.Models.Talento
@{ ViewData["Title"] = "Criar Perfil"; }

<div class="container mt-4">
    <div class="card shadow p-4" style="max-width: 800px; margin: 0 auto;">
        <h2 class="text-center mb-4">Criar Novo Perfil de Talento</h2>

        <form asp-action="Create">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label>Nome Profissional</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label>E-mail de Contacto</label>
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>País</label>
                    <input asp-for="Pais" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label>Preço por Hora (€)</label>
                    <input asp-for="Precohora" class="form-control" type="number" step="0.01" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label>Categoria</label>
                    <select asp-for="Idcategoria" class="form-control" asp-items="ViewBag.Idcategoria">
                        <option value="">-- Selecione --</option>
                    </select>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Publico" class="form-check-input" type="checkbox" />
                <label class="form-check-label">Tornar perfil público (visível para todos)</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">Criar Perfil</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>