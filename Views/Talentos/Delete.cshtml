@model ProfileMAnager.Models.Talento
@{
    ViewData["Title"] = "Eliminar Talento";
}

<h2>Eliminar Talento</h2>
<div>
    <h4>Tem a certeza que deseja eliminar este talento?</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Utilizador</dt>
        <dd class="col-sm-10">@Model.IdutilizadorNavigation?.Nome</dd>
        
        <dt class="col-sm-2">Categoria</dt>
        <dd class="col-sm-10">@Model.IdcategoriaNavigation?.Nome</dd>
        
        <dt class="col-sm-2">País</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.pais)</dd>
        
        <dt class="col-sm-2">Preço/Hora</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.precohora)</dd>
        
        <dt class="col-sm-2">Público</dt>
        <dd class="col-sm-10">@(Model.Publico == true ? "Sim" : "Não")</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Idtalento" />
        <input type="submit" value="Eliminar" class="btn btn-danger" /> 
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>