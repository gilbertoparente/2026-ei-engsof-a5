@model ProfileMAnager.Models.Talento
@{
    ViewData["Title"] = "Editar Talento";
}

<h2>Editar Talento</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Idtalento" />
    <div class="form-group">
        <label>Utilizador</label>
        <select asp-for="Idutilizador" class="form-control" asp-items="ViewBag.Idutilizadores"></select>
    </div>
    <div class="form-group">
        <label>Categoria</label>
        <select asp-for="Idcategoria" class="form-control" asp-items="ViewBag.Idcategorias"></select>
    </div>
    <div class="form-group">
        <label>País</label>
        <input asp-for="pais" class="form-control" />
    </div>
    <div class="form-group">
        <label>Preço/Hora (€)</label>
        <input asp-for="precohora" class="form-control" type="number" step="0.01" />
    </div>
    <div class="form-group">
        <label>Perfil Público</label>
        <input asp-for="Publico" type="checkbox" />
    </div>
    <br />
    <input type="submit" value="Guardar" class="btn btn-success" />
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>